# A long random string. Generate one with:
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=replace_with_long_random_string

PANEL_USERNAME=ingeniiious

# Store a bcrypt hash, not the plain-text password. Generate one with:
#   node -e "console.log(require('bcryptjs').hashSync(process.argv[1], 12))" 'YOUR_PASSWORD'
# Plain-text values still work as a fallback for first-run convenience, but
# anything internet-facing should be hashed.
PANEL_PASSWORD=$2b$12$replace_with_bcrypt_hash

PORT=4000
SHELL=/bin/bash

# Optional: enables the mobile mic / Whisper transcription button.
# Grab a key at https://platform.openai.com/api-keys
OPENAI_API_KEY=
# OPENAI_TRANSCRIBE_MODEL=whisper-1   # or gpt-4o-mini-transcribe / gpt-4o-transcribe
