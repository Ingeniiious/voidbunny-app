# Ignore everything inside backend/data/ except the shipped curated JSON.
# Pattern note: ignoring `backend/data/` (dir) blocks re-inclusion; using
# `backend/data/*` allows a `!…/cliHelpCurated.json` exception below.
backend/data/*
!backend/data/cliHelpCurated.json
